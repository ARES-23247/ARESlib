---
import type { Props } from '@astrojs/starlight/props';
---

<footer class="ares-footer">
  <div class="footer-content">
    <div class="footer-left">
      <span class="copyright">&copy; {new Date().getFullYear()} ARESLib Framework.</span>
      <span class="team-credit">Engineered for Excellence by <a href="https://www.thebluealliance.com/team/23247" target="_blank">FTC 23247</a></span>
    </div>
    <div class="footer-right">
      <a href="https://github.com/ARES-23247/ARESLib" class="social-link" aria-label="GitHub">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.1-.67.35-1.08.63-1.33-2.22-.25-4.55-1.11-4.55-4.94 0-1.1.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02a9.58 9.58 0 0 1 5 0c1.91-1.3 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.6 1.03 2.69 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/></svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .ares-footer {
    border-top: 1px solid var(--sl-color-hairline-shade);
    padding: 2rem 0;
    margin-top: 4rem;
  }
  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .copyright {
    font-size: 0.9rem;
    color: var(--sl-color-white);
    font-weight: 600;
  }
  .team-credit {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }
  .team-credit a {
    color: var(--sl-color-accent-high);
    text-decoration: none;
    font-weight: 600;
  }
  .team-credit a:hover {
    text-decoration: underline;
  }
  .social-link {
    color: var(--sl-color-gray-3);
    transition: color 0.2s;
  }
  .social-link:hover {
    color: var(--sl-color-white);
  }
</style>
