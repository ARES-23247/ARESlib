---
import type { Props } from '@astrojs/starlight/props';
---

<div class="header-override">
  <a href="/" class="custom-site-title">
    <img src="/img/ares-logo.png" alt="ARESLib Logo" width="32" height="32" class="nav-logo" />
    <span class="title-text">
      <span class="text-ares">ARES</span><span class="text-white">Lib</span> <span class="text-fade">Documentation</span>
    </span>
  </a>
  <nav class="custom-nav-links">
    <a href="/">Home</a>
    <a href="/tutorials/zero-allocation/">Tutorials</a>
    <a href="/standards/">Core Standards</a>
    <a href="https://ARES-23247.github.io/ARESLib/javadoc/index.html" target="_blank" rel="noopener noreferrer">API Reference</a>
    <a href="https://github.com/ARES-23247/ARESLib" target="_blank" rel="noopener noreferrer">GitHub</a>
  </nav>
</div>

<style>
  .header-override {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .custom-site-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    font-family: 'Orbitron', sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: 0.05em;
  }

  .nav-logo {
    object-fit: contain;
  }

  .text-ares {
    color: var(--sl-color-accent); /* Bronze */
  }
  .text-white {
    color: white;
  }
  .text-fade {
    color: var(--sl-color-text-muted);
    font-weight: 600;
    margin-left: 4px;
    font-size: 1.1rem;
  }

  .custom-nav-links {
    display: none; /* Hide on mobile defaults */
  }
  @media (min-width: 50rem) {
    .custom-nav-links {
      display: flex;
      gap: 1.5rem;
      align-items: center;
      margin-left: 1.5rem;
      border-left: 1px solid var(--sl-color-hairline-shade);
      padding-left: 1.5rem;
      height: 2rem;
    }
    .custom-nav-links a {
      color: var(--sl-color-white);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      transition: color 0.2s;
    }
    .custom-nav-links a:hover {
      color: var(--sl-color-accent-high);
    }
  }
</style>
